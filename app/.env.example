# =============================================================================
# Job Application Dashboard — environment variables
# =============================================================================
# Copy to .env.local for local dev, and set the same keys in Vercel project
# settings → Environment Variables for the deployed app.
# Each integration is optional: if a key is missing, the relevant API route
# falls back to mock data so the dashboard still renders.
# =============================================================================

# --- Airtable -----------------------------------------------------------------
# Create a Personal Access Token at https://airtable.com/create/tokens
# Scopes needed: data.records:read, schema.bases:read
# Restrict to BOTH bases: "Job Outreach" and "Automation Dev Outreach".
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXX
# Optional — defaults are hard-coded to the known base IDs. Override only if
# you clone the bases or rename them.
AIRTABLE_BASE_ID=app8aBP9UPmxYaEgI
AIRTABLE_LEADS_BASE_ID=appkusCXgR7KcEmLO

# --- Apify --------------------------------------------------------------------
# API token: https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_XXXXXXXX

# --- Apollo -------------------------------------------------------------------
# API key from Apollo settings → Integrations → API
APOLLO_API_KEY=XXXXXXXXXXXXXXXX

# --- Gmail (OAuth via Google service account or refresh token) ---------------
# Easiest: create a Google Cloud OAuth client, generate a refresh token with
# scope `https://www.googleapis.com/auth/gmail.readonly`, then store these.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_LABEL_ID=Label_3

# --- App ---------------------------------------------------------------------
# Optional: protect the dashboard with a simple bearer token (set the same
# value in your browser via cookie if you want auth). Leave blank to disable.
DASHBOARD_AUTH_TOKEN=
